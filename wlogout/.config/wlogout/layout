{
    "label" : "lock",
    "action" : "swaymsg workspace number 10 && swaylock --screenshots --clock --indicator --indicator-radius 100 --indicator-thickness 7 --effect-blur 7x5 --effect-vignette 0.5:0.5 --ring-color 10b981 --key-hl-color facc15 --inside-color 1f2937 --separator-color 000000ff --text-color ffffff --line-color 00000000 --inside-ver-color 3b82f6 --ring-ver-color 3b82f6",
    "text" : "Lock (l)",
    "keybind" : "l"
},
{
    "label" : "hibernate",
    "action" : "systemctl hibernate",
    "text" : "Hibernate (h)",
    "keybind" : "h"
},
{
    "label" : "logout",
    "action": "swaymsg exit",
    "text" : "Logout (e)",
    "keybind" : "e"
},
{
    "label" : "suspend",
    "action" : "swaymsg workspace number 10 && swaylock --screenshots --clock --indicator --indicator-radius 100 --indicator-thickness 7 --effect-blur 7x5 --effect-vignette 0.5:0.5 --ring-color 10b981 --key-hl-color facc15 --inside-color 1f2937 --separator-color 000000ff --text-color ffffff --line-color 00000000 --inside-ver-color 3b82f6 --ring-ver-color 3b82f6 & sleep 1 && systemctl suspend",
    "text" : "Suspend (u)",
    "keybind" : "u"
},
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown (s)",
    "keybind" : "s"
},
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot (r)",
    "keybind" : "r"
}
